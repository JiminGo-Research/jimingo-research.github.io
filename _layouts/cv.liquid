---
layout: default
---

<div class="post">
  <header class="post-header">
    <h1 class="post-title">
      {{ page.title }}
      {% if page.cv_pdf %}
        <a
          {% if page.cv_pdf contains '://' %}
            href="{{ page.cv_pdf }}"
          {% else %}
            href="{{ page.cv_pdf | relative_url }}"
          {% endif %}
          target="_blank"
          rel="noopener noreferrer"
          class="float-right"
        >
          <i class="fa-solid fa-file-pdf"></i>
        </a>
      {% endif %}
    </h1>
    {% if page.description %}
      <p class="post-description">{{ page.description }}</p>
    {% endif %}
  </header>

  <article>
    <div class="cv">
      {% if site.data.cv and site.data.cv.cv %}
        {% for section in site.data.cv.cv %}
          
          <a class="anchor" id="{{ section.title | slugify }}"></a>
          <div class="card mt-3 p-3">
            <h3 class="card-title font-weight-medium">{{ section.title }}</h3>
            
            <div>
              {% if section.type == 'map' %}
                <!-- 1. General Information (map 형식) -->
                <table class="table table-cv table-sm table-borderless">
                  {% for item in section.contents %}
                    <tr>
                      <td class="p-1 pr-2 font-weight-bold" style="width: 20%;"><b>{{ item.name }}</b></td>
                      <td class="p-1 pl-2 font-weight-light">{{ item.value }}</td>
                    </tr>
                  {% endfor %}
                </table>

              {% elsif section.type == 'time_table' %}
                <!-- 2. Education, Experience, Publications 등 (time_table 형식) -->
                <ul class="card-text font-weight-light list-group list-group-flush">
                  {% for item in section.contents %}
                    <li class="list-group-item" style="background: transparent; border-bottom: 1px solid rgba(0,0,0,.05); padding: 0.75rem 0;">
                      <div class="row">
                        <!-- 연도/기간 표시 (좌측) -->
                        <div class="col-xs-2 col-sm-2 col-md-2 text-center" style="font-weight: bold; color: #555;">
                          <span class="badge font-weight-bold d-block font-size-sm" style="white-space: normal;">
                            {{ item.year }}
                          </span>
                        </div>
                        
                        <!-- 본문 내용 표시 (우측) -->
                        <div class="col-xs-10 col-sm-10 col-md-10">
                          {% if item.title %}
                            <h6 class="title font-weight-bold ml-1 ml-md-4" style="margin-bottom: 0.25rem;">{{ item.title }}</h6>
                          {% endif %}
                          {% if item.institution %}
                            <table class="institution-location ml-1 ml-md-4" style="font-size: 0.9rem; font-style: italic; color: #666; margin-bottom: 0.5rem;">
                              <tr><td>{{ item.institution }}</td></tr>
                            </table>
                          {% endif %}
                          
                          <!-- 상세 bullet 목록 -->
                          {% if item.description %}
                            <ul class="items ml-1 ml-md-4" style="padding-left: 1.2rem; margin-bottom: 0;">
                              {% for desc in item.description %}
                                <li>{{ desc }}</li>
                              {% endfor %}
                            </ul>
                          {% endif %}

                          <!-- 단순 어워드/서비스 목록 (items 배열이 있을 경우) -->
                          {% if item.items %}
                            <ul class="items ml-1 ml-md-4" style="padding-left: 1.2rem; margin-bottom: 0;">
                              {% for subitem in item.items %}
                                <li>{{ subitem }}</li>
                              {% endfor %}
                            </ul>
                          {% endif %}
                        </div>
                      </div>
                    </li>
                  {% endfor %}
                </ul>

              {% elsif section.type == 'nested_list' %}
                <!-- 3. Technical Skills 등 (nested_list 형식) -->
                <div class="ml-2">
                  {% for item in section.contents %}
                    <div style="margin-bottom: 0.75rem;">
                      <strong style="display: inline-block; width: 180px; vertical-align: top;">{{ item.title }}:</strong>
                      <span style="display: inline-block; width: calc(100% - 190px); font-weight: 300;">
                        {% for subitem in item.items %}
                          {{ subitem }}{% unless forloop.last %}, {% endunless %}
                        {% endfor %}
                      </span>
                    </div>
                  {% endfor %}
                </div>

              {% endif %}
            </div>
          </div>
        {% endfor %}
      {% else %}
        <p>No CV data found. Please configure your data file properly inside _data/cv.yml.</p>
      {% endif %}
    </div>
  </article>
</div>
