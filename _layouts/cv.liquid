---
layout: default
---
{% comment %}
  Unified CV layout using al-folio's native component-include structure.
  Directly maps custom YAML structure to default layout includes.
{% endcomment %}

<div class="post">
  <header class="post-header">
    <h1 class="post-title">
      {{ page.title }}
      {% if page.cv_pdf %}
        <a
          {% if page.cv_pdf contains '://' %}
            href="{{ page.cv_pdf }}"
          {% else %}
            href="{{ page.cv_pdf | relative_url }}"
          {% endif %}
          target="_blank"
          rel="noopener noreferrer"
          class="float-right"
        >
          <i class="fa-solid fa-file-pdf"></i>
        </a>
      {% endif %}
    </h1>
    {% if page.description %}
      <p class="post-description">{{ page.description }}</p>
    {% endif %}
  </header>

  <article>
    <div class="cv">
      {% if site.data.cv.cv %}
        {% assign cv_data = site.data.cv.cv %}
      {% else %}
        {% assign cv_data = site.data.cv %}
      {% endif %}

      {% if cv_data %}
        <div class="card mt-3 p-3">
          {% for section in cv_data %}
            <a class="anchor" id="{{ section.title | slugify }}"></a>
            <div class="cv-section {% unless forloop.first %}mt-4{% endunless %}">
              <h3 class="card-title font-weight-medium">{{ section.title }}</h3>
              <div>
                {% assign entries = section.contents %}

                {% if section.type == 'map' %}
                  {% include cv/map.liquid %}
                {% elsif section.type == 'time_table' %}
                  {% include cv/time_table.liquid %}
                {% elsif section.type == 'nested_list' %}
                  {% include cv/nested_list.liquid %}
                {% else %}
                  {% for entry in entries %}
                    {% if entry.bullet %}
                      <ul class="card-text font-weight-light list-group list-group-flush">
                        <li class="list-group-item">{{ entry.bullet | markdownify }}</li>
                      </ul>
                    {% endif %}
                  {% endfor %}
                {% endif %}
              </div>
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </article>
</div>
