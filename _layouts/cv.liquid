---
layout: default
---

<div class="post">
  <header class="post-header">
    <h1 class="post-title">
      {{ page.title }}
      {% if page.cv_pdf %}
        <a
          {% if page.cv_pdf contains '://' %}
            href="{{ page.cv_pdf }}"
          {% else %}
            href="{{ page.cv_pdf | relative_url }}"
          {% endif %}
          target="_blank"
          rel="noopener noreferrer"
          class="float-right"
        >
          <i class="fa-solid fa-file-pdf"></i>
        </a>
      {% endif %}
    </h1>
    {% if page.description %}
      <p class="post-description">{{ page.description }}</p>
    {% endif %}
  </header>

  <article>
    <div class="cv">
      {% if site.data.cv.cv %}
        {% assign cv_data = site.data.cv.cv %}
      {% else %}
        {% assign cv_data = site.data.cv %}
      {% endif %}

      {% if cv_data %}
        {% for section in cv_data %}
          
          <a class="anchor" id="{{ section.title | slugify }}"></a>
          <div class="card mt-3 p-3 border-0">
            <h3 class="card-title font-weight-medium">{{ section.title }}</h3>
            
            <div>
              {% if section.type == 'map' %}
                <table class="table table-cv table-sm table-borderless" style="margin-bottom: 0.5rem;">
                  {% for item in section.contents %}
                    <tr>
                      <td class="p-1 pr-2 font-weight-bold" style="width: 20%;"><b>{{ item.name }}</b></td>
                      <td class="p-1 pl-2 font-weight-light">{{ item.value }}</td>
                    </tr>
                  {% endfor %}
                </table>

              {% elsif section.type == 'time_table' %}
                <ul class="card-text font-weight-light list-group list-group-flush">
                  {% for item in section.contents %}
                    <li class="list-group-item" style="background: transparent; border: none; padding: 0.4rem 0;">
                      <div class="row">
                        <div class="col-xs-2 col-sm-2 col-md-2 text-center" style="min-width: 120px;">
                          <span class="badge font-weight-bold d-block" style="background-color: var(--global-theme-color, #00369f); color: #fff; padding: 0.4rem 0.6rem; font-size: 0.75rem; border-radius: 4px; white-space: normal;">
                            {{ item.year }}
                          </span>
                        </div>
                        
                        <div class="col-xs-10 col-sm-10 col-md-10 mt-2 mt-sm-0">
                          {% if item.title %}
                            <h6 class="title font-weight-bold" style="margin-left: 1.5rem; margin-bottom: 0.25rem; color: var(--global-text-color);">
                              {{ item.title }}
                            </h6>
                          {% endif %}
                          
                          {% if item.institution %}
                            <p class="ml-4 font-italic" style="font-size: 0.9rem; color: var(--global-text-color-light); margin-bottom: 0.5rem; margin-left: 1.5rem;">
                              {{ item.institution }}
                            </p>
                          {% endif %}
                          
                          {% if item.description %}
                            <ul class="items" style="padding-left: 2.5rem; margin-bottom: 0; font-size: 0.95rem; list-style-type: circle;">
                              {% for desc in item.description %}
                                <li style="margin-bottom: 0.2rem;">{{ desc }}</li>
                              {% endfor %}
                            </ul>
                          {% endif %}

                          {% if item.items %}
                            <ul class="items" style="padding-left: 2.5rem; margin-bottom: 0; font-size: 0.95rem; list-style-type: circle;">
                              {% for subitem in item.items %}
                                <li style="margin-bottom: 0.2rem;">{{ subitem }}</li>
                              {% endfor %}
                            </ul>
                          {% endif %}
                        </div>
                      </div>
                    </li>
                  {% endfor %}
                </ul>

              {% elsif section.type == 'nested_list' %}
                <div style="padding-left: 0.5rem; margin-top: 0.5rem;">
                  {% for item in section.contents %}
                    <div style="margin-bottom: 0.5rem; font-size: 0.95rem;">
                      <strong style="display: inline-block; width: 180px; vertical-align: top;">{{ item.title }}:</strong>
                      <span style="display: inline-block; width: calc(100% - 190px); font-weight: 300; color: var(--global-text-color);">
                        {% for subitem in item.items %}
                          {{ subitem }}{% unless forloop.last %}, {% endunless %}
                        {% endfor %}
                      </span>
                    </div>
                  {% endfor %}
                </div>

              {% endif %}
            </div>
          </div>
        {% endfor %}
      {% endif %}
    </div>
  </article>
</div>
